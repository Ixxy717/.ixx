say upper("hello world")
say lower("HELLO")
say trim("  ixxy  ")
say replace("the cat sat", "cat", "dog")

words = split("apple,banana,grape", ",")
say count(words)
say first(words)
say last(words)
say join(words, " and ")

nums = 8, 3, 6, 1
say min(nums)
say max(nums)
say sort(nums)

say round(3.14159, 2)
say abs(-42)

say color("green", "Everything good")
say color("red", "Something wrong")
say color("yellow", "Worth a look")