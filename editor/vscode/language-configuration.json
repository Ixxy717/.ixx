{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "(", "close": ")" }
  ],
  "surroundingPairs": [
    ["\"", "\""],
    ["(", ")"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*-\\s+",
    "decreaseIndentPattern": "^\\s*---\\s*$"
  },
  "onEnterRules": []
}
